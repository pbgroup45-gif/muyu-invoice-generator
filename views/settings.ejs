<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - Muyu</title>
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.jsdelivr.net/npm/lucide@0.487.0/dist/umd/lucide.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <style>
        .size-6 { width: 1.5rem; height: 1.5rem; }
        .size-4 { width: 1rem; height: 1rem; }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="dark">
    <div class="flex h-screen bg-background" x-init="if (window.lucide) { lucide.createIcons(); }">
        <!-- Sidebar -->
        <aside class="w-64 bg-sidebar border-r border-sidebar-border flex flex-col">
            <div class="p-6 border-b border-sidebar-border">
                <div class="flex items-center gap-2">
                    <i data-lucide="receipt" class="size-6 text-sidebar-foreground"></i>
                    <h1 class="text-lg text-sidebar-foreground">Muyu: Invoice Generator</h1>
                </div>
            </div>

            <nav class="flex-1 p-4">
                <ul class="space-y-1">
                    <li>
                        <a href="/" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-sidebar-foreground hover:bg-sidebar-accent transition-colors">
                            <i data-lucide="file-text" class="size-4"></i>
                            <span>Create Invoice</span>
                        </a>
                    </li>
                    <li>
                        <a href="/past-invoices" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-sidebar-foreground hover:bg-sidebar-accent transition-colors">
                            <i data-lucide="file-spreadsheet" class="size-4"></i>
                            <span>Past Invoices</span>
                        </a>
                    </li>
                    <li>
                        <a href="/settings" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-sidebar-primary-foreground bg-sidebar-primary hover:opacity-90 transition-opacity">
                            <i data-lucide="settings" class="size-4"></i>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="p-4 border-t border-sidebar-border">
                <p class="text-xs text-muted-foreground">Logged in as: <%= email %></p>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 overflow-auto">
            <div class="max-w-4xl mx-auto p-8">
                <div class="mb-8">
                    <h2 class="text-2xl text-foreground mb-2">Settings</h2>
                    <p class="text-sm text-muted-foreground">
                        Manage your default company information and preferences
                    </p>
                </div>

                <!-- Persistent Success Message with Manual Dismiss -->
                <div x-data="{ 
                        showSuccess: new URLSearchParams(window.location.search).get('success') === '1',
                        dismiss() {
                            this.showSuccess = false;
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                     }" 
                     x-show="showSuccess"
                     x-cloak
                     class="mb-8 p-4 rounded-lg bg-accent/10 border border-accent/20 text-accent text-sm flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <i data-lucide="check-circle" class="size-4"></i>
                        <span>Settings saved successfully!</span>
                    </div>
                    <button @click="dismiss" class="text-accent/50 hover:text-accent transition-colors" title="Dismiss">
                        <i data-lucide="x" class="size-4"></i>
                    </button>
                </div>

                <div class="rounded-xl border bg-card text-card-foreground shadow border-border p-8">
                    <form action="/settings" method="POST" class="space-y-8">
                        <div class="space-y-6">
                            <div class="space-y-2">
                                <label class="text-sm font-medium text-foreground" for="companyName">
                                    Default Company Name
                                </label>
                                <input class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-base shadow-sm transition-colors bg-input border-border text-foreground placeholder:text-muted-foreground" 
                                       id="companyName" name="companyName" value="<%= profile ? profile.company_name : '' %>" placeholder="Enter default company name" />
                            </div>

                            <div class="space-y-2">
                                <label class="text-sm font-medium text-foreground" for="companyDetails">
                                    Default Company Details
                                </label>
                                <textarea class="flex min-h-[100px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-base shadow-sm bg-input border-border text-foreground placeholder:text-muted-foreground" 
                                          id="companyDetails" name="companyDetails" placeholder="Enter default company address, contact info, etc."><%= profile ? profile.company_details : '' %></textarea>
                            </div>

                            <div class="space-y-2">
                                <label class="text-sm font-medium text-foreground" for="taxRate">
                                    Default Tax Rate (%)
                                </label>
                                <div class="w-32">
                                    <input class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-base shadow-sm transition-colors bg-input border-border text-foreground placeholder:text-muted-foreground" 
                                           id="taxRate" name="taxRate" type="number" step="0.01" min="0" max="100" value="<%= profile ? profile.default_tax_rate : '' %>" placeholder="0.00" />
                                </div>
                            </div>
                        </div>

                        <div class="flex justify-end pt-4">
                            <button type="submit" 
                                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground shadow hover:bg-primary/90 h-12"
                                    style="padding-left: 4rem; padding-right: 4rem; cursor: pointer;">
                                <i data-lucide="save" class="size-4 mr-2"></i>
                                Save Settings
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
